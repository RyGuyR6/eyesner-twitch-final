{
  "name": "eyesner-lightning-twitch-package",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "preview": "remotion preview src/index.ts",
    "typecheck": "tsc --noEmit",
    "doctor": "tsx scripts/doctor.ts && npm run typecheck",
    "render:scenes": "tsx scripts/render-scenes.ts",
    "obs:package": "tsx scripts/generate-obs-package.ts",
    "build": "npm run doctor && npm run render:scenes && npm run obs:package"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "fs-extra": "^11.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.2"
  }
}
